# AUTO-POST - ตัวอย่าง .env
# คัดลอกเป็น .env แล้วกรอกค่าจริง

# Port สำหรับ Web Admin (default: 3000)
PORT=3000
# ถ้ารัน `playwright test postAll` จากเครื่อง (ไม่ผ่านปุ่มใน Admin) ให้ตั้งให้ตรงพอร์ตเซิร์ฟเวอร์
# เช่น http://localhost:3002 — ไม่ตั้งจะบันทึก Post Log ไปที่พอร์ต 3000 อาจไม่เข้า DB
# RUN_LOG_API_URL=http://localhost:3000

# PostgreSQL Database
DATABASE_URL="postgresql://user:password@host:5432/database?schema=so-autopost_jobs&sslmode=disable"
DB_SCHEMA=so_autopost_jobs
# โหมดเว็บสาธารณะ (เช่น Vercel) + worker บนเครื่องจริง
# ฝั่ง server (Vercel) ต้องตั้ง token นี้
# POST_WORKER_TOKEN=change_me_long_random_token
# ถ้าต้องการบังคับให้รับงานผ่าน queue แม้ไม่ใช่ Vercel
# POST_REMOTE_WORKER=1

# Credentials สำหรับ Users (keyed by env_key ในตาราง users)
# ใช้รูปแบบ USER_{env_key}_EMAIL และ USER_{env_key}_PASSWORD
USER_1_EMAIL=user1@example.com
USER_1_PASSWORD=your_password_here

USER_2_EMAIL=user2@example.com
USER_2_PASSWORD=your_password_here

# ฝั่งเครื่อง Worker (Local PC)
# WORKER_API_BASE=https://soworkautopost.vercel.app
# POST_WORKER_TOKEN=change_me_long_random_token
# งานโพสต์พร้อมกันกี่บัญชี (แต่ละงานเปิด Chrome แยก) — ค่าเริ่มต้นในโค้ดคือ 2; บัญชีเดียวถ้ามีปัญหาให้ใส่ 1
# WORKER_CONCURRENCY=2

# User 4 (จาก User4.json / User4Worker.json - structure เดียวกับ User1-8)
USER_4_EMAIL=your_phone_or_email
USER_4_PASSWORD=your_password_here

# Facebook API - สำหรับดึงชื่อกลุ่มจาก Group ID (ปุ่ม "ดึงชื่อจาก FB" ในฟอร์ม Groups)
# ใส่ตาม User - ใช้บัญชีที่เข้ากลุ่มนั้นได้ (หรือกรอกในฟอร์ม User > FB Access Token)
# USER_1_FB_ACCESS_TOKEN=your_token_for_user1
# USER_2_FB_ACCESS_TOKEN=your_token_for_user2
